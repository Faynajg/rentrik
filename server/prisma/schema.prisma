// Rentrik — esquema de base de datos (producción: PostgreSQL).
// Para desarrollo local con SQLite, cambia provider a "sqlite" y DATABASE_URL a "file:./dev.db".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  companyName  String? // nombre de la gestora (marca propia en Plan Agencia)
  plan         String   @default("starter") // starter | gestor | agencia
  createdAt    DateTime @default(now())

  // Moneda e impuestos
  currency String @default("EUR") // EUR | USD | MXN | COP | ARS | CLP | PEN
  ivaRate  Float  @default(0) // % de IVA/impuesto aplicable

  // Auto-envío mensual de informes a propietarios
  autoSendReports Boolean @default(false)
  autoSendDay     Int     @default(2) // día del mes en que se envían (informe del mes anterior)
  demoMode        Boolean @default(false) // el usuario está viendo datos de ejemplo

  // Facturación (Stripe)
  subscriptionStatus   String    @default("trialing") // trialing | active | past_due | canceled | none
  trialEndsAt          DateTime?
  trialReminderSent    Boolean   @default(false)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?

  properties     Property[]
  owners         Owner[]
  resetTokens    PasswordResetToken[]
  reportLogs     ReportLog[]
  importMappings ImportMapping[]
  importBatches  ImportBatch[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Propietario / inversor al que la gestora rinde cuentas.
model Owner {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())

  // Portal del propietario (acceso de solo lectura)
  passwordHash  String?
  portalEnabled Boolean @default(false)

  properties Property[]
  reportLogs ReportLog[]

  @@index([userId])
}

model Property {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownerId       String?
  owner         Owner?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  name          String
  address       String?
  currency      String   @default("EUR") // moneda de la propiedad (importes y KPIs)
  seasonsConfig String? // JSON con la configuración de temporadas (alta/media/baja)
  notes         String? // notas libres del usuario (reparaciones, incidencias…)
  notesUpdatedAt DateTime? // última vez que se guardó la nota
  isDemo        Boolean  @default(false) // propiedad de datos de ejemplo (modo demo)
  createdAt     DateTime @default(now())

  reservations  Reservation[]
  expenses      Expense[]
  incidents     Incident[]
  importBatches ImportBatch[]

  @@index([userId])
  @@index([ownerId])
}

// Registro de incidencias por propiedad (reparaciones, quejas, problemas).
model Incident {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  type        String // reparacion | queja | problema | otro
  description String
  cost        Float    @default(0)
  date        DateTime
  month       String // YYYY-MM (según la fecha)
  createdAt   DateTime @default(now())

  @@index([propertyId])
  @@index([month])
}

model Reservation {
  id                 String    @id @default(cuid())
  propertyId         String
  property           Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  platform           String    @default("Otra") // Airbnb | Booking | VRBO | Otra
  guestName          String?
  bookingDate        DateTime?
  checkIn            DateTime
  checkOut           DateTime
  nights             Int
  grossRevenue       Float     @default(0)
  platformCommission Float     @default(0)
  netRevenue         Float     @default(0)
  currency           String    @default("EUR") // moneda original antes de convertir a EUR
  month              String // "YYYY-MM" (según fecha de entrada) para agrupar
  createdAt          DateTime  @default(now())

  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([month])
  @@index([importBatchId])
}

// Mapeo de columnas recordado por usuario, identificado por la huella de las
// cabeceras del archivo. Permite re-importar el mismo formato sin volver a mapear.
model ImportMapping {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  headersHash String // hash de las cabeceras normalizadas
  mapping     String // JSON con { checkIn, checkOut, grossRevenue, ... }
  label       String? // cabeceras legibles, para mostrar al usuario
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, headersHash])
  @@index([userId])
}

// Lote de importación: historial y base para deshacer.
model ImportBatch {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  filename   String
  platform   String    @default("Otra")
  count      Int       @default(0)
  totalGross Float     @default(0)
  currency   String    @default("EUR")
  dateFrom   DateTime?
  dateTo     DateTime?
  createdAt  DateTime  @default(now())

  reservations Reservation[]

  @@index([userId])
  @@index([propertyId])
}

model Expense {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  category   String // fijo | variable | plataforma | gestion
  concept    String // p.ej. "Limpieza", "Hipoteca"
  amount     Float    @default(0)
  isPercent  Boolean  @default(false) // para comisión de gestora (% sobre ingresos)
  month      String // "YYYY-MM"
  createdAt  DateTime @default(now())

  @@index([propertyId])
  @@index([month])
}

// Historial de informes generados/enviados (pestaña Propietarios).
model ReportLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownerId    String?
  owner      Owner?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  propertyId String?
  type       String // owner | manager
  month      String
  sentTo     String? // email destino si se envió por correo
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([ownerId])
}
