# ─── Rentrik · variables de entorno del servidor ──────────────────────
# Copia este archivo a `.env` y rellena los valores:  cp .env.example .env

# ── Base de datos ─────────────────────────────────────────────────────
# Desarrollo (SQLite, sin instalar nada):
DATABASE_URL="file:./dev.db"
# Producción (PostgreSQL). Cambia también el provider en prisma/schema.prisma a "postgresql":
# DATABASE_URL="postgresql://usuario:password@host:5432/rentrik"

# ── Servidor ──────────────────────────────────────────────────────────
# No definas PORT en Railway: la inyecta la plataforma.
PORT=4000

# ── Autenticación ─────────────────────────────────────────────────────
# Usa una cadena larga y aleatoria en producción (p. ej. `openssl rand -hex 32`).
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# ── Frontend ──────────────────────────────────────────────────────────
# Origen del cliente (CORS y enlaces de los emails). En producción: https://rentrik.app
CLIENT_ORIGIN="http://localhost:5173"

# ── Prueba gratuita ───────────────────────────────────────────────────
TRIAL_DAYS=14

# ── Stripe (opcional; vacío = modo simulado sin cobros reales) ─────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Price IDs de cada plan (opcional; ya vienen valores por defecto en el código):
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_GESTOR=""
STRIPE_PRICE_AGENCIA=""

# ── Email / SMTP (opcional; vacío = modo desarrollo, se registra en consola) ──
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Rentrik <no-reply@rentrik.app>"
